# =============================================================================
# Telecom Churn MLOps — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# AI / LLM Providers (required for Phase 2 data enrichment re-runs)
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# ---------------------------------------------------------------------------
# Inter-service networking
# Docker Compose sets this automatically via the service DNS name.
# Override locally if the embedding service runs on a non-default host.
# ---------------------------------------------------------------------------
EMBEDDING_SERVICE_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# HuggingFace (optional — suppresses unauthenticated request warnings)
# Higher rate limits and faster downloads with a token.
# https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
ENV=local  # local | staging | production

# ---------------------------------------------------------------------------
# MLflow (optional overrides — defaults are set in params.yaml)
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=file:./mlruns

# ---------------------------------------------------------------------------
# AWS (required for Phase 8 CI/CD and ECS deployment)
# LocalStack emulator values
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# LocalStack endpoint
AWS_ENDPOINT_URL=http://localstack:4566

# ECR registry base URL (LocalStack)
ECR_REGISTRY=localhost:4566

# S3 bucket storing DVC-tracked model artifacts for Fargate containers
ARTIFACTS_S3_BUCKET=telecom-churn-artifacts-local

# ECS cluster name (used by Makefile deploy targets)
ECS_CLUSTER=telecom-churn-cluster

# ---------------------------------------------------------------------------
# Docker Hub (required for Docker Scout vulnerability scanning in CD)
# https://hub.docker.com/settings/security
# ---------------------------------------------------------------------------
DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=

# ---------------------------------------------------------------------------
# GitHub Actions (set these as repository secrets, not in .env)
# Listed here for documentation — never store in this file.
# ---------------------------------------------------------------------------
# AWS_ROLE_ARN         → GitHub Secret: IAM Role ARN for OIDC federation
# ALB_DNS_PRED         → GitHub Variable: ALB DNS for prediction-api health check
# ALB_DNS_GRADIO       → GitHub Variable: ALB DNS for gradio-ui health check
